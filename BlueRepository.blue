                            value: /amountCaptured
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: ${steps['Validate and Apply Settlement'].nextAmountCaptured}
