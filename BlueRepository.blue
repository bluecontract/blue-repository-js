                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: confirmTransactionDetailsUpdated
              steps:
                items:
                  - name: Merge Transaction Details Update
                    type:
                      blueId: ExZxT61PSpWHpEAtP2WKMXXqxEYN7Z13j7Zv36Dp99kS
                    code:
                      type:
                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                      value: |
                        const request =
                          event && event.message ? event.message.request : null;

                        if (!request || typeof request !== 'object' || Array.isArray(request)) {
                          throw new Error('Transaction details update payload must be an object.');
                        }
                        if (
                          !request.transactionDetails ||
                          typeof request.transactionDetails !== 'object' ||
                          Array.isArray(request.transactionDetails)
                        ) {
                          throw new Error(
                            'Transaction details update payload must include transactionDetails object.'
                          );
                        }

                        const current = document('/transactionDetails');
                        const next =
                          current && typeof current === 'object' && !Array.isArray(current)
                            ? { ...current }
                            : {};
                        const patch = request.transactionDetails;

                        const patchKeys = Object.keys(patch);
                        let index = 0;
                        while (index < patchKeys.length) {
                          const key = patchKeys[index];
                          next[key] = patch[key];
                          index += 1;
                        }

                        return { nextTransactionDetails: next, events: [request] };
