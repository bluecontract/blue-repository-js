                    code:
                      type:
                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                      value: |
                        const request =
                          event && event.message ? event.message.request : null;

                        if (!request || typeof request !== 'object' || Array.isArray(request)) {
                          throw new Error('Payee assignment payload must be an object.');
                        }
                        if (typeof request.payeeRef !== 'string') {
                          throw new Error('Payee assignment payload must include payeeRef.');
                        }

                        const current = document('/transactionDetails');
                        const next =
                          current && typeof current === 'object' && !Array.isArray(current)
                            ? { ...current }
                            : {};
                        next.payeeRef = request.payeeRef;

                        return { nextTransactionDetails: next, events: [request] };
